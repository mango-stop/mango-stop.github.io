---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostTile from '../components/PostTile.astro';
import { CATEGORIES, SITE_DESCRIPTION } from '../lib/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const home = await getEntry('home', 'home');
const heroTitle = home?.data.title ?? '학부연구생의 연구 기록';
const heroTagline = home?.data.tagline ?? SITE_DESCRIPTION;

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const countByCategory = Object.fromEntries(
  Object.keys(CATEGORIES).map((key) => [
    key,
    posts.filter((p) => p.data.category === key).length,
  ])
);
---

<BaseLayout wide>
  <section class="hero">
    <h1>{heroTitle}</h1>
    <p class="tagline">{heroTagline}</p>
    <div class="category-links">
      {
        Object.entries(CATEGORIES).map(([key, c]) => (
          <a class="category-link" href={`${base}/categories/${c.slug}/`}>
            {c.label}
            <span class="cat-count">{countByCategory[key]}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="posts">
    <div class="grid">
      {posts.map((post) => <PostTile post={post} />)}
    </div>
  </section>

  <style>
    .hero {
      padding: 3.2rem 0 2.6rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2rem;
    }

    .hero h1 {
      font-size: clamp(1.7rem, 3.5vw, 2.2rem);
      margin: 0 0 0.6rem;
      line-height: 1.3;
    }

    .tagline {
      color: var(--text-muted);
      font-size: 1rem;
      margin: 0 0 1.5rem;
      max-width: 34rem;
    }

    .category-links {
      display: flex;
      gap: 1.4rem;
      flex-wrap: wrap;
    }

    .category-link {
      display: inline-flex;
      align-items: baseline;
      gap: 0.4rem;
      color: var(--text);
      font-size: 0.92rem;
      font-weight: 600;
      border-bottom: 1px solid transparent;
      transition: border-color 0.15s ease;
    }

    .category-link:hover {
      text-decoration: none;
      border-bottom-color: var(--text);
    }

    .cat-count {
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--text-muted);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr));
      gap: 1rem;
      align-items: stretch;
    }

    @media (max-width: 480px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
