---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const about = await getEntry('about', 'about');
if (!about) {
  throw new Error('src/content/about/about.md 파일이 필요합니다.');
}
const { Content } = await render(about);
const { name, role, affiliation, email, github } = about.data;
---

<BaseLayout title="About">
  <h1 class="page-title">About</h1>

  <section class="profile">
    {name && <p class="name">{name}</p>}
    <p class="role">
      {role}
      <span class="affiliation">@ {affiliation}</span>
    </p>

    <ul class="links">
      <li>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="m3 7 9 6 9-6"></path>
        </svg>
        <a href={`mailto:${email}`}>{email}</a>
      </li>
      <li>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 1.5A10.5 10.5 0 0 0 8.7 22c.5.1.7-.2.7-.5v-1.9c-2.9.6-3.5-1.2-3.5-1.2-.5-1.2-1.2-1.5-1.2-1.5-1-.7.1-.7.1-.7 1 .1 1.6 1.1 1.6 1.1.9 1.6 2.5 1.1 3.1.9.1-.7.4-1.1.7-1.4-2.3-.3-4.8-1.2-4.8-5.2 0-1.1.4-2 1.1-2.8-.1-.2-.5-1.3.1-2.7 0 0 .9-.3 2.9 1.1a10 10 0 0 1 5.2 0c2-1.4 2.9-1.1 2.9-1.1.6 1.4.2 2.5.1 2.7.7.8 1.1 1.7 1.1 2.8 0 4-2.5 4.9-4.8 5.2.4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5A10.5 10.5 0 0 0 12 1.5Z"></path>
        </svg>
        <a href={`https://github.com/${github}`} target="_blank" rel="noopener">github.com/{github}</a>
      </li>
    </ul>
  </section>

  <div class="prose">
    <Content />
  </div>

  <style>
    .page-title {
      font-size: 1.7rem;
      margin: 0 0 1.4rem;
    }

    .profile {
      padding: 1.6rem 1.7rem;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: var(--bg-card);
      margin-bottom: 2rem;
    }

    .name {
      margin: 0 0 0.2rem;
      font-size: 1.25rem;
      font-weight: 700;
    }

    .role {
      margin: 0;
      font-size: 1.02rem;
      font-weight: 600;
    }

    .affiliation {
      font-weight: 500;
      color: var(--text-muted);
      margin-left: 0.25rem;
    }

    .links {
      list-style: none;
      margin: 1.1rem 0 0;
      padding: 1.1rem 0 0;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }

    .links li {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.93rem;
      color: var(--text-muted);
    }

    .links a {
      color: var(--text);
    }

    .links a:hover {
      color: var(--accent);
    }
  </style>
</BaseLayout>
