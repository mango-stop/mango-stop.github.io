---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostTile from '../../components/PostTile.astro';
import { CATEGORIES, type CategoryKey } from '../../lib/site';

export async function getStaticPaths() {
  return Object.keys(CATEGORIES).map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const categoryInfo = CATEGORIES[category as CategoryKey];

const posts = (
  await getCollection(
    'posts',
    ({ data }) => !data.draft && data.category === category
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={categoryInfo.label} wide>
  <h1 class="page-title">{categoryInfo.label}</h1>
  <p class="count">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
  <div class="grid">
    {posts.map((post) => <PostTile post={post} />)}
  </div>

  <style>
    .count {
      padding-bottom: 1.2rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1.4rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr));
      gap: 1rem;
      align-items: stretch;
    }

    @media (max-width: 480px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
