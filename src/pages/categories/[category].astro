---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORIES, type CategoryKey } from '../../lib/site';

export async function getStaticPaths() {
  return Object.keys(CATEGORIES).map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const categoryInfo = CATEGORIES[category as CategoryKey];

const posts = (
  await getCollection(
    'posts',
    ({ data }) => !data.draft && data.category === category
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={categoryInfo.label}>
  <h1 class="page-title">{categoryInfo.label}</h1>
  <p class="count">{posts.length}개의 글</p>
  <section>
    {posts.map((post) => <PostCard post={post} />)}
  </section>

  <style>
    .page-title {
      margin-bottom: 0.2rem;
    }

    .count {
      color: var(--text-muted);
      font-size: 0.9rem;
      margin-top: 0;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
  </style>
</BaseLayout>
