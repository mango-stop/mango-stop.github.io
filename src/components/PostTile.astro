---
import type { CollectionEntry } from 'astro:content';
import { CATEGORIES, formatDate, firstImageFromMarkdown } from '../lib/site';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const category = CATEGORIES[post.data.category];
const cover = post.data.cover ?? firstImageFromMarkdown(post.body ?? '');
---

<a class="tile" href={`${base}/posts/${post.id}/`}>
  {
    cover && (
      <div class="thumb">
        <img src={cover} alt="" loading="lazy" />
      </div>
    )
  }
  <div class="tile-body">
    <div class="tile-top">
      <span class="cat" style={`color: ${category.color}`}>{category.label}</span>
      <time datetime={post.data.pubDate.toISOString()}>
        {formatDate(post.data.pubDate)}
      </time>
    </div>
    <h3 class="tile-title">{post.data.title}</h3>
    <p class="tile-desc">{post.data.description}</p>
    {
      post.data.tags.length > 0 && (
        <div class="tile-tags">
          {post.data.tags.map((tag) => (
            <span class="tile-tag">#{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</a>

<style>
  .tile {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1.2rem 1.3rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text);
    transition: border-color 0.18s ease, background-color 0.18s ease;
  }

  .tile:hover {
    text-decoration: none;
    border-color: var(--text-muted);
  }

  .thumb {
    flex: 0 0 6.2rem;
    width: 6.2rem;
    height: 6.2rem;
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-soft);
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    display: block;
  }

  .tile-body {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-width: 0;
    flex: 1;
  }

  .tile-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.7rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  .cat {
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .tile-title {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.45;
  }

  .tile:hover .tile-title {
    color: var(--accent);
  }

  .tile-desc {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.91rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tile-tags {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
    padding-top: 0.15rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
