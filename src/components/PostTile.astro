---
import type { CollectionEntry } from 'astro:content';
import { CATEGORIES, formatDate } from '../lib/site';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const category = CATEGORIES[post.data.category];
---

<a class="tile" href={`${base}/posts/${post.id}/`}>
  <div class="tile-top">
    <span class="cat" style={`color: ${category.color}`}>{category.label}</span>
    <time datetime={post.data.pubDate.toISOString()}>
      {formatDate(post.data.pubDate)}
    </time>
  </div>
  <h3 class="tile-title">{post.data.title}</h3>
  <p class="tile-desc">{post.data.description}</p>
  {
    post.data.tags.length > 0 && (
      <div class="tile-tags">
        {post.data.tags.map((tag) => (
          <span class="tile-tag">#{tag}</span>
        ))}
      </div>
    )
  }
</a>

<style>
  .tile {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.35rem 1.4rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text);
    transition: border-color 0.18s ease, background-color 0.18s ease;
  }

  .tile:hover {
    text-decoration: none;
    border-color: var(--text-muted);
  }

  .tile-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.7rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  .cat {
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .tile-title {
    margin: 0;
    font-size: 1.12rem;
    line-height: 1.45;
  }

  .tile:hover .tile-title {
    color: var(--accent);
  }

  .tile-desc {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tile-tags {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
